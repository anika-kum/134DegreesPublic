{
  "expo": {
    "name": "134 Degrees",
    "slug": "134-degrees",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "sfhousing",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a3c5e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.sfhousing.advocate"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a3c5e"
      },
      "package": "org.sfhousing.advocate"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
